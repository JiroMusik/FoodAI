# AI Provider API Key (configure in-app Settings page, or set here for Gemini default)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: database directory (defaults to current working directory)
# DB_DIR=/path/to/data

# Optional: HTTP port for plain-text server (default: 3001)
# HTTP_PORT=3001

# Set to "production" to serve pre-built frontend from dist/
# NODE_ENV=production
